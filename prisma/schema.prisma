generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String                  @id @default(cuid())
  name                   String?
  email                  String                  @unique
  emailVerified          DateTime?
  image                  String?
  passwordHash           String?
  role                   Role                    @default(reader)
  telefone               String?
  biNuit                 String?
  kycStatus              KycStatus               @default(nao_iniciado)
  kycMotivoRejeicao      String?
  criadoEm               DateTime                @default(now())
  accounts               Account[]
  contactRequests        ContactRequest[]        @relation("ContactBuyer")
  ndasComoComprador      NDA[]                   @relation("NdaBuyer")
  newsletterSubscription NewsletterSubscription?
  payments               Payment[]
  projects               Project[]               @relation("ProjectOwner")
  reactions              Reaction[]
  sessions               Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Project {
  id               String                  @id @default(cuid())
  ownerId          String
  seccao           Seccao
  titulo           String
  descricao        String
  categoria        String
  sector           String
  localizacao      String
  nivelVerificacao NivelVerificacao        @default(nao_aplicavel)
  estado           EstadoProjecto          @default(rascunho)
  boostActivoAte   DateTime?
  dataLancamento   DateTime?
  linkSite         String?
  criadoEm         DateTime                @default(now())
  motivoRejeicao   String?
  faixaPreco       String?
  notaVerificacao  String?
  dadosSensiveis   String?
  contactRequests  ContactRequest[]
  documentos       DocumentoSensivel[]
  editorialPicks   EditorialPick[]
  ndas             NDA[]
  payments         Payment[]
  owner            User                    @relation("ProjectOwner", fields: [ownerId], references: [id])
  reactions        Reaction[]
  checklists       VerificationChecklist[]

  @@map("projects")
}

model VerificationChecklist {
  id             String  @id @default(cuid())
  projectId      String
  tipo           String
  respostasJson  String
  documentosUrls String
  estado         String  @default("pendente")
  project        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("verification_checklists")
}

model Reaction {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  tipo      String   @default("like")
  criadoEm  DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId, tipo])
  @@map("reactions")
}

model NDA {
  id        String   @id @default(cuid())
  projectId String
  buyerId   String
  aceiteEm  DateTime @default(now())
  ip        String
  pago      Boolean  @default(false)
  criadoEm  DateTime @default(now())
  buyer     User     @relation("NdaBuyer", fields: [buyerId], references: [id])
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("ndas")
}

model ContactRequest {
  id        String   @id @default(cuid())
  projectId String
  buyerId   String
  estado    String   @default("pendente")
  criadoEm  DateTime @default(now())
  buyer     User     @relation("ContactBuyer", fields: [buyerId], references: [id])
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("contact_requests")
}

model Payment {
  id              String   @id @default(cuid())
  tipo            String
  projectId       String?
  userId          String
  metodo          String
  comprovativoUrl String?
  estado          String   @default("pendente")
  confirmadoPor   String?
  criadoEm        DateTime @default(now())
  motivoRejeicao  String?
  referencia      String   @unique
  project         Project? @relation(fields: [projectId], references: [id])
  user            User     @relation(fields: [userId], references: [id])

  @@map("payments")
}

model DocumentoSensivel {
  id            String    @id @default(cuid())
  projectId     String
  tipo          String
  urlEncriptado String
  expiraEm      DateTime?
  criadoEm      DateTime  @default(now())
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("documentos_sensiveis")
}

model NewsletterSubscription {
  id       String   @id @default(cuid())
  userId   String   @unique
  estado   String   @default("gratis")
  criadoEm DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("newsletter_subscriptions")
}

model EditorialPick {
  id               String  @id @default(cuid())
  projectId        String
  seccao           Seccao
  posicao          Int
  semanaReferencia String
  project          Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("editorial_picks")
}

enum Role {
  reader
  founder
  admin
}

enum KycStatus {
  nao_iniciado
  pendente
  aprovado
  rejeitado
}

enum Seccao {
  lancamento
  ideia
  em_alta
  em_funcionamento
  a_venda
}

enum NivelVerificacao {
  nao_verificado
  parcialmente_verificado
  verificado
  nao_aplicavel
}

enum EstadoProjecto {
  rascunho
  pendente_revisao
  publicado
  rejeitado
  arquivado
}
